# Required
ORPHEUS_MODAL_URL=https://your-org--orpheus-3b-tts-orpheustts-web.modal.run
GCS_BUCKET_NAME=your-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional (defaults shown)
GCS_OBJECT_PREFIX=tts
GCS_SIGNED_URL_EXPIRY_MINUTES=30
MODAL_REQUEST_TIMEOUT_SECONDS=180
MODAL_CONNECT_TIMEOUT_SECONDS=10
MODAL_RETRY_BACKOFF_SECONDS=0.5
MAX_BATCH_SIZE=16
SPEAKERS_CACHE_TTL_SECONDS=60
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
