project_id = "sb-gcp-project-01"
region     = "europe-west1"
app        = "sunflower-grpo-test"
repo       = "sunflower-grpo-test"
port       = 8080

# Bump this (or pass via -var) to deploy a new image.
image_tag = "latest"

sunflower_upstream_url = "https://sb-modal-ws--sunflower-grpo-vllm-web.modal.run"
sunbird_prod_url       = "https://api.sunbird.ai"
sunbird_prod_token     = "REPLACE_WITH_PROD_BEARER_TOKEN"

# OpenAI-compatible Sunflower-14B upstream (sunflower_14b_openai_vllm_modal.py).
# Must include the trailing `/v1`.
sunflower_openai_url   = "https://sb-modal-ws--sunflower-14b-openai-serve.modal.run/v1"
# Same value as Modal secret `vllm-api-key`. Generate with scripts/generate_api_key.sh.
vllm_api_key           = "REPLACE_WITH_VLLM_API_KEY"
sunflower_openai_model = "Sunbird/Sunflower-14B"

upstream_timeout      = 600
rate_limit_per_minute = "100/minute"
rate_limit_per_day    = "1000/day"

cpu           = "1"
memory        = "1Gi"
min_instances = 0
max_instances = 5

allow_public        = true
deletion_protection = false
